    </div>
    <div class="team-card reveal" style="transition-delay:0.35s">
      <div class="team-card-placeholder"><span>EM</span></div>
      <div class="team-card-info">
        <p class="team-card-name">Eduard Moreno</p>
        <p class="team-card-role">{t.team.researcher_m} &middot; IDIAP-JGol</p>
      </div>
      <div class="team-card-links"><a href="#" class="team-link-btn">ORCID</a></div>
    </div>
    <div class="team-card reveal" style="transition-delay:0.4s">
      <div class="team-card-placeholder"><span>JM</span></div>
      <div class="team-card-info">
        <p class="team-card-name">Juan José Moreno</p>
        <p class="team-card-role">{t.team.researcher_m} &middot; IDIAP-JGol</p>
      </div>
      <div class="team-card-links"><a href="#" class="team-link-btn">ORCID</a></div>
    </div>
    <div class="team-card reveal" style="transition-delay:0.45s">
      <div class="team-card-placeholder"><span>JM</span></div>
      <div class="team-card-info">
        <p class="team-card-name">Joan Moyà</p>
        <p class="team-card-role">{t.team.researcher_m} &middot; UAB</p>
      </div>
      <div class="team-card-links"><a href="#" class="team-link-btn">ORCID</a></div>
    </div>
    <div class="team-card reveal" style="transition-delay:0.5s">
      <div class="team-card-placeholder"><span>JP</span></div>
      <div class="team-card-info">
        <p class="team-card-name">Joel Piqué</p>
        <p class="team-card-role">{t.team.researcher_m} &middot; Hospital Olot</p>
      </div>
      <div class="team-card-links"><a href="#" class="team-link-btn">ORCID</a></div>
    </div>
    <div class="team-card reveal" style="transition-delay:0.55s">
      <div class="team-card-placeholder"><span>MP</span></div>
      <div class="team-card-info">
        <p class="team-card-name">Marina Prat Carreño</p>
        <p class="team-card-role">{t.team.researcher_f} &middot; IIIA-CSIC</p>
      </div>
      <div class="team-card-links"><a href="#" class="team-link-btn">ORCID</a></div>
    </div>
    <div class="team-card reveal" style="transition-delay:0.6s">
      <div class="team-card-placeholder"><span>VU</span></div>
      <div class="team-card-info">
        <p class="team-card-name">Valentina Umaña</p>
        <p class="team-card-role">{t.team.researcher_f} &middot; IIIA-CSIC</p>
