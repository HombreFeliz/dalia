<!-- PHASES -->
<section id="phases">
  <div class="phases-inner">
    <p class="section-label reveal">{t.phases.label}</p>
    <h2 class="section-title reveal" set:html={t.phases.title}></h2>
    <div class="timeline">
      <div class="timeline-line"></div>
      <div class="timeline-progress" id="timelineProgress"></div>
      <div class="timeline-cards">
        <div class="timeline-card active" id="phase1">
          <div class="timeline-dot"></div>
          <p class="timeline-year">{t.phases.phase1.year}</p>
          <h3 class="timeline-phase" set:html={t.phases.phase1.title}></h3>
          <p class="timeline-desc">{t.phases.phase1.desc}</p>
        </div>
        <div class="timeline-card" id="phase2">
          <div class="timeline-dot"></div>
          <p class="timeline-year">{t.phases.phase2.year}</p>
          <h3 class="timeline-phase" set:html={t.phases.phase2.title}></h3>
          <p class="timeline-desc">{t.phases.phase2.desc}</p>
        </div>
        <div class="timeline-card" id="phase3">
          <div class="timeline-dot"></div>
          <p class="timeline-year">{t.phases.phase3.year}</p>
          <h3 class="timeline-phase" set:html={t.phases.phase3.title}></h3>
          <p class="timeline-desc">{t.phases.phase3.desc}</p>
        </div>
        <div class="timeline-card" id="phase4">
          <div class="timeline-dot"></div>
          <p class="timeline-year">{t.phases.phase4.year}</p>
          <h3 class="timeline-phase" set:html={t.phases.phase4.title}></h3>
          <p class="timeline-desc">{t.phases.phase4.desc}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ENTITIES -->
<section id="entities">
  <div class="entities-inner">
    <p class="section-label reveal">{t.entities.label}</p>
    <h2 class="section-title reveal">{t.entities.title}</h2>
    <div class="entities-grid reveal">
      <div class="entity-card">
        <span class="entity-badge">{t.entities.coordinator}</span>
        <p class="entity-name">Institut d'Investigació en Intel·ligència Artificial – CSIC</p>
        <p class="entity-location">Barcelona, Cataluña</p>
      </div>
      <div class="entity-card">
        <span class="entity-badge">{t.entities.participant}</span>
        <p class="entity-name">Escuela Andaluza de Salud Pública</p>
        <p class="entity-location">Granada, Andalucía</p>
      </div>
      <div class="entity-card">
        <span class="entity-badge">{t.entities.participant}</span>
        <p class="entity-name">Fundació Hospital d'Olot i Comarcal de la Garrotxa</p>
        <p class="entity-location">Olot, Cataluña</p>
      </div>
      <div class="entity-card">
        <span class="entity-badge">{t.entities.participant}</span>
        <p class="entity-name">Institut d'Investigació en Atenció Primària Jordi Gol – ICS</p>
        <p class="entity-location">Barcelona, Cataluña</p>
      </div>
      <div class="entity-card">
        <span class="entity-badge">{t.entities.participant}</span>
        <p class="entity-name">Universitat Autònoma de Barcelona</p>
