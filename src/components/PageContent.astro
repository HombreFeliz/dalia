---
import { useTranslations, type Lang } from '../i18n/translations';
import DaliaInteractiva from './DaliaInteractiva.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const altLang = lang === 'es' ? 'en' : 'es';
const altHref = lang === 'es' ? '/en/' : '/';
const currentHref = lang === 'es' ? '/' : '/en/';
---

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <button class="mobile-menu-close" id="menuClose">&#x2715;</button>
  <ul>
    <li><a href="#about" class="menu-link">{t.nav.project}</a></li>
    <li><a href="#team" class="menu-link">{t.nav.team}</a></li>
    <li><a href="#phases" class="menu-link">{t.nav.phases}</a></li>
    <li><a href="#entities" class="menu-link">{t.nav.entities}</a></li>
    <li><a href="#publications" class="menu-link">{t.nav.publications}</a></li>
    <li><a href="#contact" class="menu-link">{t.nav.contact}</a></li>
  </ul>
  <div class="mobile-menu-lang">
    <a href={currentHref} class={`lang-option ${lang === 'es' ? 'active' : ''}`}>ES</a>
    <span style="color:#333;">/</span>
    <a href={altHref} class={`lang-option ${lang === 'en' ? 'active' : ''}`}>EN</a>
  </div>
</div>

<!-- NAV -->
<nav id="navbar">
  <a href={currentHref} class="nav-logo">DALIA</a>
  <ul class="nav-links">
    <li><a href="#about">{t.nav.project}</a></li>
    <li><a href="#team">{t.nav.team}</a></li>
    <li><a href="#phases">{t.nav.phases}</a></li>
    <li><a href="#entities">{t.nav.entities}</a></li>
    <li><a href="#publications">{t.nav.publications}</a></li>
    <li><a href="#contact">{t.nav.contact}</a></li>
  </ul>
  <div class="nav-right">
    <div class="lang-toggle">
      <a href="/" class={lang === 'es' ? 'active' : ''}>ES</a>
      <span style="color:#ccc;">/</span>
      <a href="/en/" class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>
    <div class="hamburger">
      <span></span><span></span><span></span>
    </div>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-left">
    <p class="hero-tag">{t.hero.tag}</p>
    <h1 class="hero-title">DALIA</h1>
    <p class="hero-subtitle-line1">{t.hero.line1}</p>
    <p class="hero-subtitle-line2" set:html={t.hero.line2}></p>
    <div class="hero-ctas">
      <a href="#about" class="btn-primary">{t.hero.cta1}</a>
      <a href="#team" class="btn-secondary">{t.hero.cta2}</a>
    </div>
  </div>
  <div class="hero-right">
    <DaliaInteractiva class="dalia-interactiva" />
    <div class="hero-meta">
      <p>{t.hero.meta}</p>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="about-grid reveal">
    <div class="about-text">
      <p class="section-label">{t.about.label}</p>
      <h2 class="section-title" set:html={t.about.title}></h2>
      <p>{t.about.p1}</p>
      <p>{t.about.p2}</p>
      <p>{t.about.p3}</p>
    </div>
    <div class="about-objectives">
      <h3>{t.about.objectivesTitle}</h3>
      <div class="objective-item">
        <span class="objective-num">01</span>
        <p>{t.about.obj1}</p>
      </div>
      <div class="objective-item">
        <span class="objective-num">02</span>
        <p>{t.about.obj2}</p>
      </div>
      <div class="objective-item">
        <span class="objective-num">03</span>
        <p>{t.about.obj3}</p>
      </div>
      <div class="objective-item">
        <span class="objective-num">04</span>
        <p>{t.about.obj4}</p>
      </div>
    </div>
  </div>
</section>

<!-- TEAM -->
<section id="team">
