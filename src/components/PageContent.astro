        <a href="#" class="team-link-btn">ORCID</a>
        <a href="#" class="team-link-btn">Perfil</a>
      </div>
    </div>
    <div class="team-card reveal" style="transition-delay:0.05s">
      <div class="team-card-placeholder"><span>VA</span></div>
